---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import HiwiItem from "../../components/HiwiItem.astro";

const hiwis = (await getCollection("hiwis")).sort(
    (a, b) => a.data.order - b.data.order,
);

---

<Layout title="Hiwi Positions">
    <div class="max-w-7xl mx-auto px-4 py-12 sm:py-20 space-y-20">
        <div class="max-w-3xl mx-auto text-center mb-16">
            <h1 class="text-4xl font-bold text-gray-900 mb-4">
                Open Hiwi Positions
            </h1>
            <p class="text-lg text-gray-600">
                We are always looking for motivated student assistants (Hiwis) to
                join our research group. Below is a list of open positions.
            </p>

            <p class="text-lg text-gray-600 mt-4">
                Please directly contact the supervisor(s) if you are interested.
            </p>
        </div>

        <section>
            <h2 class="mb-8 pl-4 border-l-4 border-blue-600 text-2xl font-bold">
                Available Positions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {hiwis.map((hiwi) => <HiwiItem entry={hiwi} />)}
            </div>

            {
                hiwis.length === 0 && (
                    <div class="text-center py-20">
                        <p class="text-gray-500">
                            No open Hiwi positions available at the moment.
                        </p>
                    </div>
                )
            }
        </section>
    </div>
</Layout>
